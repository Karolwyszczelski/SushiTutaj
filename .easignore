# EAS Build – kopia .gitignore, ale google-services.json NIE jest wykluczony
# żeby FCM działał po zbudowaniu APK.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry Config File
.env.sentry-build-plugin

# Firebase service account keys (NIGDY nie commituj!)
*-firebase-adminsdk-*.json
serviceAccountKey*.json
# mobile/google-services.json  ← CELOWO NIE WYKLUCZAMY – potrzebny do FCM w buildzie

# Mobile app build artifacts
mobile/android/
mobile/ios/
mobile/.expo/
.env*.local
mobile/build-*.apk
